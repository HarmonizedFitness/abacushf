generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/harmonized-fitness/app/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  name              String
  password          String
  role              UserRole         @default(CLIENT)
  image             String?
  phone             String?
  dateOfBirth       DateTime?
  fitnessGoals      String?
  isActive          Boolean          @default(true)
  isArchived        Boolean          @default(false)
  daysPerWeek       Int?             @default(2)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  accounts          Account[]
  bookings          Booking[]
  creditPurchases   CreditPurchase[]
  notifications     Notification[]
  personalRecords   PersonalRecord[]
  sessions          Session[]
  workoutSessions   WorkoutSession[]
  favoriteExercises Exercise[]       @relation("ExerciseToUser")
  progressEntries   ProgressEntry[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Booking {
  id                    String        @id @default(cuid())
  userId                String
  startTime             DateTime
  endTime               DateTime
  status                BookingStatus @default(CONFIRMED)
  notes                 String?
  creditsUsed           Int           @default(1)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  googleCalendarEventId String?       @unique
  lastSyncAt            DateTime?
  syncError             String?
  syncStatus            SyncStatus    @default(PENDING)
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model CreditPurchase {
  id                    String        @id @default(cuid())
  userId                String
  credits               Int
  amount                Decimal       @db.Decimal(10, 2)
  stripePaymentIntentId String?
  status                PaymentStatus @default(PENDING)
  packageName           String
  pricePerCredit        Decimal       @db.Decimal(10, 2)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_purchases")
}

model Exercise {
  id               String            @id @default(cuid())
  name             String
  description      String?
  instructions     String?
  category         String
  muscleGroups     String[]
  equipment        String?
  difficulty       String?           // NEW: Difficulty Level (beginner, intermediate, advanced)
  forceType        String?           // NEW: Push/Pull/Static
  isFavorite       Boolean           @default(false) // NEW: Admin-controlled global favorite
  imageUrl         String?
  videoUrl         String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  personalRecords  PersonalRecord[]
  workoutExercises WorkoutExercise[]
  favoritedBy      User[]            @relation("ExerciseToUser") // Keep for backward compatibility

  @@map("exercises")
}

model WorkoutSession {
  id        String                 @id @default(cuid())
  userId    String
  date      DateTime
  duration  Int
  notes     String?
  status    WorkoutStatus          @default(COMPLETED)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  groups    WorkoutExerciseGroup[]
  exercises WorkoutExercise[]
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workout_sessions")
}

model WorkoutExerciseGroup {
  id                String            @id @default(cuid())
  workoutSessionId  String
  type              GroupType         @default(REGULAR)
  name              String?
  notes             String?
  order             Int
  rounds            Int?
  restBetweenRounds Int?
  createdAt         DateTime          @default(now())
  workoutSession    WorkoutSession    @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exercises         WorkoutExercise[]

  @@map("workout_exercise_groups")
}

model WorkoutExercise {
  id               String                @id @default(cuid())
  workoutSessionId String
  exerciseId       String
  notes            String?
  order            Int
  createdAt        DateTime              @default(now())
  groupId          String?
  orderInGroup     Int?
  exercise         Exercise              @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  group            WorkoutExerciseGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  workoutSession   WorkoutSession        @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  sets             WorkoutSet[]

  @@map("workout_exercises")
}

model WorkoutSet {
  id                String          @id @default(cuid())
  workoutExerciseId String
  setNumber         Int
  reps              Int?
  weight            Decimal?        @db.Decimal(10, 2)
  duration          Int?
  restTime          Int?
  notes             String?
  isDropSet         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@map("workout_sets")
}

model PersonalRecord {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  weight     Decimal? @db.Decimal(10, 2)
  reps       Int?
  duration   Int?
  volume     Decimal? @db.Decimal(10, 2)
  notes      String?
  achievedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@map("personal_records")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model BusinessConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("business_config")
}

model AvailabilitySettings {
  id            String           @id @default(cuid())
  type          AvailabilityType
  dayOfWeek     Int?
  startTime     String?
  endTime       String?
  breakName     String?
  blackoutDate  DateTime?
  blackoutStart DateTime?
  blackoutEnd   DateTime?
  isRecurring   Boolean          @default(false)
  recurringType RecurringType?
  title         String?
  description   String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("availability_settings")
}

model CalendarSyncLog {
  id           String        @id @default(cuid())
  operation    SyncOperation
  status       SyncStatus
  bookingId    String?
  eventId      String?
  errorMessage String?
  details      Json?
  createdAt    DateTime      @default(now())

  @@map("calendar_sync_logs")
}

model ProgressEntry {
  id           String              @id @default(cuid())
  userId       String
  type         ProgressEntryType
  value        Decimal             @db.Decimal(10, 2)
  unit         String?
  notes        String?
  recordedAt   DateTime
  recordedBy   String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("progress_entries")
}

enum UserRole {
  CLIENT
  ADMIN
}

enum ProgressEntryType {
  BODY_WEIGHT
  BMI
  BODY_FAT_PERCENTAGE
  MUSCLE_MASS
  CHEST_MEASUREMENT
  WAIST_MEASUREMENT
  HIP_MEASUREMENT
  ARM_MEASUREMENT
  THIGH_MEASUREMENT
  NECK_MEASUREMENT
  STRENGTH_SCORE
  CARDIO_SCORE
  FLEXIBILITY_SCORE
  CUSTOM_MEASUREMENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum WorkoutStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  WORKOUT_REMINDER
  CREDIT_LOW
  CREDIT_PURCHASED
  PERSONAL_RECORD
  SYSTEM_UPDATE
  WELCOME
}

enum GroupType {
  REGULAR
  SUPERSET
  CIRCUIT
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
  CONFLICT
}

enum AvailabilityType {
  WORKING_HOURS
  BREAK
  BLACKOUT_DATE
  BLACKOUT_PERIOD
}

enum RecurringType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum SyncOperation {
  CREATE
  UPDATE
  DELETE
  SYNC
}
