
# Production Environment Configuration Template
# Copy this file to .env and update with your production values

# Database Configuration
DATABASE_URL="postgresql://username:password@hostname:port/database"

# NextAuth Configuration
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="your-super-secure-nextauth-secret-key-here"

# API Keys
ABACUSAI_API_KEY="your-abacusai-api-key"

# Production Settings
NODE_ENV="production"

# Optional: Allow production seeding (ONLY set to true if needed)
# ALLOW_PRODUCTION_SEED="false"

# Optional: Confirm production cleanup (ONLY set to true when intentionally cleaning)
# CONFIRM_PRODUCTION_CLEANUP="false"

# Optional: Enable demo features in production (NOT recommended)
# ENABLE_DEMO_FEATURES="false"

# Security: Force production seed (NOT recommended)
# FORCE_PRODUCTION_SEED="false"
